#!/bin/bash
# Manager Portfolio — apre il Manager come app standalone
# Funziona sia dalla cartella Portfolio AEI che da /Applications

APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
MANAGER=""

for NAME in ".Manager Portfolio.html" "Manager Portfolio.html"; do
  for DIR in "$APP_DIR" "$HOME/Desktop/Portfolio AEI" "$HOME/Documents/Portfolio AEI" "$HOME/Portfolio AEI"; do
    if [ -f "$DIR/$NAME" ]; then
      MANAGER="$DIR/$NAME"
      break 2
    fi
  done
done

# Spotlight come ultimo tentativo
if [ -z "$MANAGER" ]; then
  FOUND=$(mdfind -name ".Manager Portfolio.html" 2>/dev/null | head -1)
  if [ -n "$FOUND" ] && [ -f "$FOUND" ]; then
    MANAGER="$FOUND"
  fi
fi

if [ -z "$MANAGER" ]; then
  osascript -e 'display alert "Manager non trovato" message "Il file Manager Portfolio.html non è stato trovato. Assicurati che la cartella Portfolio AEI sia sul Desktop o in Documenti." as critical'
  exit 1
fi

# Apri con il browser predefinito
open "$MANAGER"
